# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — sga-web
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# El archivo .env nunca se sube al repositorio (está en .gitignore).
# Para producción, configura estas mismas variables en el dashboard de Vercel.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — obtén estos valores en:
# https://supabase.com/dashboard → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu-anon-key-aqui
